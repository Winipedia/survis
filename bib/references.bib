@article{Leite2020Survey,
  abstract = {A comprehensive systematic literature review of DevOps as a collaborative, multidisciplinary effort to automate continuous software delivery while ensuring correctness and reliability. Using snowballing methodology across over 120 sources spanning academic publications and industry reports from 2008 to 2018, the authors produce a DevOps conceptual map that organises key concepts including continuous integration, continuous delivery, infrastructure as code, microservices, and monitoring, correlating them with specific automation tools. The survey examines recurring challenges such as cultural transformation between development and operations teams, security integration (DevSecOps), and difficulties of adopting DevOps in regulated or embedded-systems domains.},
  author = {Leite, Leonardo and Rocha, Carla and Kon, Fabio and Milojicic, Dejan and Meirelles, Paulo},
  doi = {10.1145/3359981},
  journal = {ACM Computing Surveys},
  keywords = {type:survey, devops, systematic_literature_review, continuous_delivery, infrastructure_as_code},
  number = {6},
  publisher = {ACM},
  volume = {52},
  title = {A Survey of {DevOps} Concepts and Challenges},
  year = {2020}
}

@inproceedings{Hilton2016Usage,
  abstract = {One of the first large-scale empirical investigations into continuous integration (CI) in open-source software. The authors employ three complementary research methods: a repository mining study of 34,544 GitHub projects, an analysis of over 1.5 million Travis CI builds, and a survey of 442 developers. The study finds that CI adoption is growing steadily and is positively associated with more frequent software releases, establishing an empirical baseline for CI research.},
  author = {Hilton, Michael and Tunnell, Timothy and Huang, Kai and Marinov, Darko and Dig, Danny},
  booktitle = {Proceedings of the 31st IEEE/ACM International Conference on Automated Software Engineering},
  doi = {10.1145/2970276.2970358},
  keywords = {type:empirical, ci_cd, continuous_integration, open_source, repository_mining},
  publisher = {ACM},
  series = {ASE '16},
  title = {Usage, Costs, and Benefits of Continuous Integration in Open-Source Projects},
  year = {2016}
}

@inproceedings{Vasilescu2015Quality,
  abstract = {An investigation of whether CI adoption measurably affects software quality and developer productivity in open-source GitHub projects. Using large-scale historical data from GHTorrent and fixed-effects negative binomial regression models, the study finds that CI adoption significantly increases the number of outside contributions that project teams can integrate without producing any observable decline in code quality, providing quasi-experimental evidence for the engineering benefits of CI.},
  author = {Vasilescu, Bogdan and Yu, Yue and Wang, Huaimin and Devanbu, Premkumar and Filkov, Vladimir},
  booktitle = {Proceedings of the 10th Joint Meeting on Foundations of Software Engineering},
  doi = {10.1145/2786805.2786850},
  keywords = {type:empirical, ci_cd, continuous_integration, productivity, software_quality},
  publisher = {ACM},
  series = {ESEC/FSE '15},
  title = {Quality and Productivity Outcomes Relating to Continuous Integration in {GitHub}},
  year = {2015}
}

@inproceedings{Rahman2018Characteristics,
  abstract = {An investigation of which characteristics of infrastructure as code (IaC) scripts are associated with defects, with the aim of helping DevOps practitioners improve script quality and avoid security violations. Mining open-source version control systems from Mozilla, OpenStack, and Wikimedia, the study identifies 14 code-level and four churn-based characteristics alongside 12 process characteristics that correlate with defects, establishing a foundational empirical basis for IaC quality research.},
  author = {Rahman, Akond},
  booktitle = {Proceedings of the 40th International Conference on Software Engineering: Companion Proceedings},
  doi = {10.1145/3183440.3183452},
  keywords = {type:empirical, iac_quality, defect_prediction, infrastructure_as_code, devops},
  publisher = {ACM},
  series = {ICSE '18},
  title = {Characteristics of Defective Infrastructure as Code Scripts in {DevOps}},
  year = {2018}
}

@inproceedings{Sharma2016Configuration,
  abstract = {An extension of the concept of code smells to Infrastructure as Code (IaC), specifically targeting Puppet scripts. The authors propose a catalogue of 24 configuration smells partitioned into 13 implementation smells and 11 design smells, validated empirically by analysing 4,621 Puppet repositories from GitHub encompassing approximately 8.9 million lines of code. Design smells exhibit around 9% higher average co-occurrence among themselves compared to implementation smells, establishing a foundational framework for automated quality assessment of configuration code at scale.},
  author = {Sharma, Tushar and Fragkoulis, Marios and Spinellis, Diomidis},
  booktitle = {Proceedings of the 13th International Conference on Mining Software Repositories},
  doi = {10.1145/2901739.2901761},
  keywords = {type:empirical, iac_quality, code_smells, puppet, configuration_management},
  publisher = {ACM},
  series = {MSR '16},
  title = {Does Your Configuration Code Smell?},
  year = {2016}
}

@inproceedings{Rahman2020Gang,
  abstract = {A defect taxonomy for infrastructure as code (IaC) scripts derived through qualitative analysis of 1,448 defect-related commits from OpenStack repositories. Applying open coding, the authors identify eight defect categories: configuration data, dependency, documentation, idempotency, conditional logic, security, service, and syntax. The taxonomy was validated via a survey of 66 industry practitioners. A frequency analysis of 80,425 commits across 291 repositories showed that configuration data defects are the most prevalent in practice.},
  author = {Rahman, Akond and Mahdavi-Hezaveh, Rezvan and Williams, Laurie},
  booktitle = {Proceedings of the 42nd International Conference on Software Engineering},
  doi = {10.1145/3377811.3380409},
  keywords = {type:empirical, iac_quality, defect_taxonomy, infrastructure_as_code, idempotency},
  publisher = {ACM},
  series = {ICSE '20},
  title = {Gang of Eight: A Defect Taxonomy for Infrastructure as Code Scripts},
  year = {2020}
}

@article{Rahman2019Source,
  abstract = {An investigation of which source code properties are associated with defects in Infrastructure as Code (IaC) scripts. Defect prediction models are constructed and validated across 2,439 Puppet scripts drawn from four distinct datasets. The models reveal that lines of code and hard-coded strings exhibit the strongest correlation with defective scripts, providing empirical guidance for practitioners to focus inspection and testing efforts on IaC scripts exhibiting these properties.},
  author = {Rahman, Akond and Williams, Laurie},
  doi = {10.1016/j.infsof.2019.04.013},
  journal = {Information and Software Technology},
  keywords = {type:empirical, iac_quality, defect_prediction, puppet, static_analysis},
  publisher = {Elsevier},
  title = {Source Code Properties of Defective Infrastructure as Code Scripts},
  year = {2019}
}

@inproceedings{Bogart2016Break,
  abstract = {An investigation of how developers across three major software ecosystems (Node.js/npm, R/CRAN, and Eclipse) make decisions about breaking API changes and negotiate the costs those changes impose on downstream dependents. Using semi-structured interviews and grounded theory coding, the study reveals that the three ecosystems differ substantially in their community values: npm tolerates rapid change, R/CRAN enforces conservative stability norms through centralised gatekeeping, and Eclipse maintains strict backward-compatibility guarantees. The study argues that making community values and accepted tradeoffs explicit is essential for designing healthier dependency management infrastructure.},
  author = {Bogart, Christopher and K{\"a}stner, Christian and Herbsleb, James and Thung, Ferdian},
  booktitle = {Proceedings of the 24th ACM SIGSOFT International Symposium on Foundations of Software Engineering},
  doi = {10.1145/2950290.2950325},
  keywords = {type:qualitative, pkg_ecosystem, api_evolution, dependency_management, breaking_changes},
  publisher = {ACM},
  series = {FSE '16},
  title = {How to Break an {API}: Cost Negotiation and Community Values in Three Software Ecosystems},
  year = {2016}
}

@inproceedings{Abdalkareem2017Trivial,
  abstract = {An introduction of the concept of trivial packages — npm modules that encapsulate simple, single-purpose functionality — and an investigation of why developers rely on them despite concerns about software supply-chain fragility. Mining over 230,000 npm packages and 38,000 JavaScript applications, the study finds that trivial packages constitute 16.8% of the npm ecosystem. A survey of 88 developers reveals adoption is driven by a perception of good implementation quality, yet only 45.2% of trivial packages include tests. Furthermore, 11.5% of trivial packages carry more than twenty transitive dependencies, introducing non-trivial breakage risk.},
  author = {Abdalkareem, Rabe and Nourry, Olivier and Wehaibi, Sullivan and Mujahid, Suhaib and Shihab, Emad},
  booktitle = {Proceedings of the 11th Joint Meeting on Foundations of Software Engineering},
  doi = {10.1145/3106237.3106267},
  keywords = {type:empirical, pkg_ecosystem, npm, trivial_packages, dependency_management},
  publisher = {ACM},
  series = {ESEC/FSE '17},
  title = {Why Do Developers Use Trivial Packages? An Empirical Case Study on npm},
  year = {2017}
}

@inproceedings{Wittern2016Look,
  abstract = {A large-scale empirical study of the npm package ecosystem examining its structure and evolution across two perspectives: the npm registry (over 230,000 packages) and the use of packages in publicly available GitHub applications. Analysing ecosystem growth trajectories, inter-package dependency networks, download metrics, and semantic versioning adoption, the study finds that npm grew at an exceptional rate, dependency graphs exhibit a highly skewed structure, and version adoption by downstream consumers lags behind releases, raising practical concerns about update propagation and vulnerability exposure.},
  author = {Wittern, Erik and Suter, Philippe and Rajagopalan, Shriram},
  booktitle = {Proceedings of the 13th International Conference on Mining Software Repositories},
  doi = {10.1145/2901739.2901743},
  keywords = {type:empirical, pkg_ecosystem, npm, ecosystem_analysis, dependency_networks},
  publisher = {ACM},
  series = {MSR '16},
  title = {A Look at the Dynamics of the {JavaScript} Package Ecosystem},
  year = {2016}
}